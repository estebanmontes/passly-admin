# Neon PostgreSQL — pooled connection (for Prisma Client)
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/passly?sslmode=require"

# Neon PostgreSQL — direct connection (for migrations)
DIRECT_DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/passly?sslmode=require"

# Better Auth
BETTER_AUTH_SECRET="openssl rand -base64 32"
BETTER_AUTH_URL="http://localhost:3000"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Public
NEXT_PUBLIC_APP_URL="http://localhost:3000"
