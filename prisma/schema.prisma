generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────

enum EventCategory {
  MUSIC
  CONFERENCE
  SPORTS
  THEATER
  FESTIVAL
  COMEDY
  WORKSHOP
  NETWORKING
  OTHER
}

enum EventStatus {
  DRAFT
  SCHEDULED
  ON_SALE
  SOLD_OUT
  CANCELLED
  COMPLETED
}

enum EventAvailability {
  AVAILABLE
  LIMITED
  SOLD_OUT
}

enum TicketTierStatus {
  ACTIVE
  PAUSED
  SOLD_OUT
  EXPIRED
}

enum BadgeVariant {
  NEW
  HOT
  LIMITED
  VIP
  EARLY_BIRD
  SOLD_OUT
}

enum ArtistRole {
  HEADLINER
  SUPPORT
  DJ
  HOST
  SPEAKER
  PERFORMER
}

enum OrderStatus {
  PENDING
  CONFIRMED
  FAILED
  REFUNDED
  CANCELLED
}

enum PaymentMethod {
  CREDIT_CARD
  DEBIT_CARD
  PAYPAL
  APPLE_PAY
  GOOGLE_PAY
  BANK_TRANSFER
}

enum PassStatus {
  VALID
  USED
  EXPIRED
  CANCELLED
  TRANSFERRED
}


enum NewsletterStatus {
  SUBSCRIBED
  UNSUBSCRIBED
}

enum Currency {
  USD
  EUR
  GBP
  MXN
  COP
}


// ─── Auth Models ────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  role          String    @default("CUSTOMER")
  emailVerified Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts  Account[]
  sessions  Session[]
  orders    Order[]
  passes    Pass[]
  favorites Favorite[]
  organizer Organizer?

  @@map("users")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verifications")
}

// ─── Multi-Tenant Models ────────────────────────────────────────────

model Organizer {
  id          String   @id @default(cuid())
  userId      String   @unique
  name        String
  slug        String   @unique
  description String?
  logoUrl     String?
  website     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  events Event[]
  venues Venue[]

  @@map("organizers")
}

model Venue {
  id          String   @id @default(cuid())
  organizerId String
  name        String
  address     String
  city        String
  state       String?
  country     String
  latitude    Float?
  longitude   Float?
  capacity    Int?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organizer Organizer @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  events    Event[]

  @@index([organizerId])
  @@map("venues")
}

// ─── Event Models ───────────────────────────────────────────────────

model Event {
  id           String            @id @default(cuid())
  organizerId  String
  venueId      String?
  title        String
  slug         String            @unique
  description  String?
  category     EventCategory
  status       EventStatus       @default(DRAFT)
  availability EventAvailability @default(AVAILABLE)
  coverUrl     String?
  startDate    DateTime
  endDate      DateTime?
  doorsOpen    DateTime?
  currency     Currency          @default(USD)
  featured     Boolean           @default(false)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  organizer   Organizer     @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  venue       Venue?        @relation(fields: [venueId], references: [id], onDelete: SetNull)
  badges      EventBadge[]
  artists     EventArtist[]
  ticketTiers TicketTier[]
  orders      Order[]
  favorites   Favorite[]

  @@index([organizerId])
  @@index([status])
  @@index([startDate])
  @@map("events")
}

model EventBadge {
  id      String       @id @default(cuid())
  eventId String
  variant BadgeVariant
  label   String

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("event_badges")
}

model Artist {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  imageUrl  String?
  bio       String?
  createdAt DateTime @default(now())

  events EventArtist[]

  @@map("artists")
}

model EventArtist {
  id       String     @id @default(cuid())
  eventId  String
  artistId String
  role     ArtistRole @default(PERFORMER)
  order    Int        @default(0)

  event  Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  artist Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@unique([eventId, artistId])
  @@map("event_artists")
}

// ─── Ticket Inventory ───────────────────────────────────────────────

model TicketTier {
  id            String           @id @default(cuid())
  eventId       String
  name          String
  description   String?
  price         Float
  currency      Currency         @default(USD)
  totalQuantity Int
  soldCount     Int              @default(0)
  reservedCount Int              @default(0)
  maxPerOrder   Int              @default(10)
  status        TicketTierStatus @default(ACTIVE)
  salesStart    DateTime?
  salesEnd      DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  event      Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@index([eventId])
  @@map("ticket_tiers")
}

// ─── Checkout Flow ──────────────────────────────────────────────────

model Order {
  id            String        @id @default(cuid())
  userId        String
  eventId       String
  orderNumber   String        @unique
  status        OrderStatus   @default(PENDING)
  subtotal      Float
  fees          Float         @default(0)
  total         Float
  currency      Currency      @default(USD)
  paymentMethod PaymentMethod?
  paymentIntentId String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  items OrderItem[]
  passes Pass[]

  @@index([userId])
  @@index([eventId])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id           String @id @default(cuid())
  orderId      String
  ticketTierId String
  quantity     Int
  unitPrice    Float
  subtotal     Float

  order      Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  ticketTier TicketTier @relation(fields: [ticketTierId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([ticketTierId])
  @@map("order_items")
}

// ─── QR-Code Tickets ────────────────────────────────────────────────

model Pass {
  id        String     @id @default(cuid())
  orderId   String
  userId    String
  qrCode    String     @unique
  status    PassStatus @default(VALID)
  scannedAt DateTime?
  createdAt DateTime   @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([qrCode])
  @@index([status])
  @@index([orderId])
  @@index([userId])
  @@map("passes")
}

// ─── Engagement ─────────────────────────────────────────────────────

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  eventId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@map("favorites")
}

model NewsletterSubscription {
  id        String           @id @default(cuid())
  email     String           @unique
  status    NewsletterStatus @default(SUBSCRIBED)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@map("newsletter_subscriptions")
}
